<%- include("../partials/head") %>

<body>
  

  <main>

    <% if (title) { %>
      <h1><%= title %></h1>
    <% } else { %>
      <h1>Server Error</h1>
    <% } %>

    <% if (message) { %>
      <p><%- message %></p>
    <% } else { %>
      <p>😅 Something went wrong, but we’re working on it!</p>
    <% } %>

    <p>Try refreshing the page or go back home.</p>

    <a href="/">⬅ Back to Home</a>

  </main>


</body>
</html>